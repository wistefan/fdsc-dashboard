{
  "id": "packet-delivery-service",
  "defaultOidcScope": "default",
  "oidcScopes": {
    "default": {
      "credentials": [
        {
          "type": "VerifiableCredential",
          "trustedIssuersLists": [
            "http://til:8080"
          ]
        }
      ]
    },
    "delivery": {
      "credentials": [
        {
          "type": "PacketDeliveryCredential",
          "trustedIssuersLists": [
            "http://til:8080"
          ],
          "trustedParticipantsLists": [
            {
              "url": "http://tir:8080",
              "type": "ebsi"
            }
          ]
        }
      ],
      "dcql": {
        "credentials": [
          {
            "id": "delivery-credential",
            "format": "vc+sd-jwt",
            "claims": [
              {
                "id": "delivery-address",
                "path": ["address", "street"]
              },
              {
                "id": "delivery-status",
                "path": ["status"],
                "values": ["active", "pending"]
              }
            ],
            "meta": {
              "vct_values": ["PacketDeliveryCredential"]
            },
            "trusted_authorities": [
              {
                "type": "etsi_tl",
                "values": ["http://trusted-authority:8080"]
              }
            ]
          }
        ],
        "credential_sets": [
          {
            "options": [["delivery-credential"]],
            "required": true,
            "purpose": {
              "reason": "Verify delivery authorization"
            }
          }
        ]
      }
    }
  }
}
