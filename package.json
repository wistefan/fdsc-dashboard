{
  "name": "fdsc-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/",
    "download:specs": "bash scripts/download-specs.sh",
    "generate:api": "bash scripts/generate-api-clients.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "license:check": "license-check-and-add check -f license-check-and-add-config.json",
    "license:apply": "license-check-and-add add -f license-check-and-add-config.json"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-i18n": "^9.10.2",
    "vue-router": "^4.3.0",
    "vuetify": "^3.5.8"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "jsdom": "^29.0.1",
    "license-check-and-add": "^4.0.5",
    "openapi-typescript-codegen": "^0.30.0",
    "prettier": "^3.2.5",
    "sass": "^1.72.0",
    "typescript": "~5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-vuetify": "^2.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^2.0.6"
  }
}
