# Pinned versions (release tags) for upstream OpenAPI specifications.
# The upstream repos use git tags for releases – always pin to a release tag,
# never to a branch name.  To bump a version, update these values then run:
#   npm run download:specs && npm run generate:api

TIL_VERSION="0.8.0"
TIR_VERSION="0.8.0"
CCS_VERSION="3.4.2"
ODRL_VERSION="1.4.3"
